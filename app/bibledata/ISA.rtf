 {\b
3} Tetapi karena kalian memilih cara hidup yang jauh dari kehendak-Ku,\par\pard\plain\hyphpar} {	
dan menyukai dosa-dosamu yang najis itu,\par\pard\plain\hyphpar} {	
maka kurban persembahanmu pun najis di mata-Ku!\par\pard\plain\hyphpar} {	
Ketika kalian menyembelih sapi jantan,\par\pard\plain\hyphpar} {	
bagi-Ku kalian seperti sedang membunuh orang.\par\pard\plain\hyphpar} {	
Domba muda yang kalian persembahkan,\par\pard\plain\hyphpar} {	
bagi-Ku itu sama najisnya seperti anjing mati.\par\pard\plain\hyphpar} {	
Persembahan gandum-gandumanmu menjijikkan seperti darah babi.\par\pard\plain\hyphpar} {	
Dan saat kalian membakar kemenyan,\par\pard\plain\hyphpar} {	
di mata-Ku kalian seperti sedang menyembah berhala.\par\pard\plain\hyphpar} {	
 {\b
4} Jadi, Aku juga memilih untuk mengacaukan kalian\par\pard\plain\hyphpar} {	
dengan mendatangkan bencana-bencana yang kalian takutkan.\par\pard\plain\hyphpar} {	
Sebab ketika Aku memanggil, kalian tidak mau menjawab.\par\pard\plain\hyphpar} {	
Ketika Aku berbicara, kalian tidak mau mendengar.\par\pard\plain\hyphpar} {	
Sebaliknya kalian melakukan apa yang jahat di mata-Ku\par\pard\plain\hyphpar} {	
dan memilih apa yang Aku benci.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
5} Tetapi kata TUHAN kepada orang-orang yang mau mendengar dan takut akan peringatan-Nya:\par\pard\plain\hyphpar} {	
Saudara-saudaramu sebangsa membenci kalian\par\pard\plain\hyphpar} {	
dan mengucilkanmu karena kalian percaya kepada-Ku.\par\pard\plain\hyphpar} {	
Mereka mengejekmu dengan berkata,\par\pard\plain\hyphpar} {	
\u8220?Mintalah TUHANmu itu melakukan sesuatu yang dahsyat\par\pard\plain\hyphpar} {	
supaya kami melihat kalian bersukacita.\u8221?\par\pard\plain\hyphpar} {	
Tetapi Aku, TUHAN, menegaskan, sesungguhnya merekalah yang akan menjadi malu.\par\pard\plain\hyphpar} {	
 {\b
6} Akan ada kegemparan di kota.\par\pard\plain\hyphpar} {	
Terdengar bunyi kegaduhan dari rumah TUHAN\par\pard\plain\hyphpar} {	
ketika Aku membalas kejahatan musuh-musuh-Ku.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Nubuat Yesaya: Sukacita Yerusalem ketika keadaannya dipulihkan\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
7} Bayangkan bila seorang ibu hamil\par\pard\plain\hyphpar} {	
tiba-tiba melahirkan bayinya begitu saja tanpa rasa sakit.\par\pard\plain\hyphpar} {	
 {\b
8} Tentu kalian belum pernah mendengar atau melihat kejadian seperti itu, bukan?\par\pard\plain\hyphpar} {	
Tetapi itulah yang akan terjadi pada Yerusalem.\par\pard\plain\hyphpar} {	
Yerusalem akan mendapatkan anak-anaknya, yaitu penduduknya, dalam sekejap saja,\par\pard\plain\hyphpar} {	
seperti perempuan melahirkan dengan sangat cepat tanpa kesakitan.\par\pard\plain\hyphpar} {	
Tiba-tiba saja, dalam waktu singkat, sekumpulan bangsa sudah terbentuk di Sion.\par\pard\plain\hyphpar} {	
 {\b
9} Sebab kata TUHAN,\par\pard\plain\hyphpar} {	
\u8220?Akankah Aku menghalangi anak yang akan lahir?\par\pard\plain\hyphpar} {	
Akankah Aku mencegah bayi keluar dari kandungan,\par\pard\plain\hyphpar} {	
padahal Aku yang membuat ibunya bersalin?\par\pard\plain\hyphpar} {	
Tidak mungkin!\u8221?\par\pard\plain\hyphpar} {	
Demikianlah janji Allahmu.\par\pard\plain\hyphpar} {	
 {\b
10} Jadi, hai semua orang yang mencintai Yerusalem\par\pard\plain\hyphpar} {	
dan yang meratapinya sewaktu Yerusalem terpuruk,\par\pard\plain\hyphpar} {	
bersukacita dan bergembiralah\par\pard\plain\hyphpar} {	
karena keadaan Yerusalem akan dipulihkan.\par\pard\plain\hyphpar} {	
 {\b
11} Kelak, kalian akan sejahtera dan dipuaskan\par\pard\plain\hyphpar} {	
oleh segala kelimpahannya,\par\pard\plain\hyphpar} {	
bagaikan seorang bayi dikenyangkan oleh air susu ibunya.\par\pard\plain\hyphpar} {	
 {\b
12} Sebab TUHAN telah berkata,\par\pard\plain\hyphpar} {	
\u8220?Aku akan mengalirkan damai ke Yerusalem seperti sungai\par\pard\plain\hyphpar} {	
dan mendatangkan kekayaan bangsa-bangsa ke sana seperti arus air.\par\pard\plain\hyphpar} {	
Maka kalian akan menikmatinya,\par\pard\plain\hyphpar} {	
seperti seorang anak yang dibuai di gendongan sang ibu\par\pard\plain\hyphpar} {	
dan diayun-ayun di pangkuannya.\par\pard\plain\hyphpar} {	
 {\b
13} Bagaikan seorang ibu menghibur anaknya,\par\pard\plain\hyphpar} {	
demikianlah Aku akan menghiburmu.\par\pard\plain\hyphpar} {	
Ya, kalian akan mengalami penghiburan di Yerusalem.\u8221?\par\pard\plain\hyphpar} {	
 {\b
14} Ketika melihatnya, hatimu akan bersukacita\par\pard\plain\hyphpar} {	
dan tubuhmu menjadi segar seperti rumput hijau.\par\pard\plain\hyphpar} {	
TUHAN akan menunjukkan kuasa-Nya kepada para hamba-Nya,\par\pard\plain\hyphpar} {	
dan menyatakan murka-Nya kepada musuh-musuh-Nya.\par\pard\plain\hyphpar} {	
 {\b
15} Ketahuilah, TUHAN akan datang dalam api\par\pard\plain\hyphpar} {	
dengan kereta perang-Nya yang sedahsyat angin topan.\par\pard\plain\hyphpar} {	
Dia akan mengobarkan amarah-Nya.\par\pard\plain\hyphpar} {	
Hardikan-Nya membakar seperti nyala api.\par\pard\plain\hyphpar} {	
 {\b
16} TUHAN akan menghukum seluruh dunia dengan api dan pedang-Nya,\par\pard\plain\hyphpar} {	
dan banyaklah orang yang mati oleh-Nya.\par\pard\plain\hyphpar} {	
 {\b
17} Orang-orang yang melakukan penyucian diri\par\pard\plain\hyphpar} {	
untuk beribadah di taman-taman pemujaan dewa,\par\pard\plain\hyphpar} {	
yang mengikuti ritual di tengah penyembahan berhala,\par\pard\plain\hyphpar} {	
serta memakan daging babi, tikus, dan binatang haram lainnya,\par\pard\plain\hyphpar} {	
mereka semua akan dihabisi sekaligus.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
18} Kata TUHAN:\par\pard\plain\hyphpar} {	
Aku tahu benar segala pikiran dan perbuatan mereka.\par\pard\plain\hyphpar} {	
Ketika tiba waktunya, Aku akan mengumpulkan orang dari segala bangsa dan bahasa,\par\pard\plain\hyphpar} {	
sehingga mereka menyaksikan cahaya kehadiran-Ku.\par\pard\plain\hyphpar} {	
 {\b
19} Aku akan memberikan suatu tanda di antara mereka.\par\pard\plain\hyphpar} {	
Orang-orang yang selamat dari murka-Ku akan Aku utus kepada bangsa-bangsa untuk memberitakan kemuliaan-Ku\u8212?\par\pard\plain\hyphpar} {	
ke Tarsis, Libia, dan Lud, yang terkenal dengan pemanah ulung,\par\pard\plain\hyphpar} {	
ke Tubal, Yunani, dan pulau-pulau yang jauh,\par\pard\plain\hyphpar} {	
yang belum pernah mendengar tentang-Ku ataupun melihat kemuliaan-Ku.\par\pard\plain\hyphpar} {	
 {\b
20} Dan bangsa-bangsa itu akan mengantar pulang saudara-saudara kalian, umat Israel, yang tersebar di negeri mereka\par\pard\plain\hyphpar} {	
sebagai bentuk penghormatan mereka kepada-Ku,\par\pard\plain\hyphpar} {	
sama seperti ketika kalian, bangsa Israel, mengantarkan persembahan ke rumah TUHAN dalam wadah yang bersih.\par\pard\plain\hyphpar} {	
Mereka akan mengantar orang Israel dengan tandu, kereta, kuda, bagal, dan unta,\par\pard\plain\hyphpar} {	
ke gunung-Ku yang kudus di Yerusalem.\par\pard\plain\hyphpar} {	
 {\b
21} Bahkan dari antara bangsa-bangsa lain itu\par\pard\plain\hyphpar} {	
ada yang akan Aku jadikan imam dan pelayan-Ku,\par\pard\plain\hyphpar} {	
setara dengan suku Lewi.\par\pard\plain\hyphpar} {	
Aku, TUHAN, menegaskannya.\par\pard\plain\hyphpar} {	
 {\b
22} Sebagaimana langit dan bumi baru yang Aku jadikan nanti akan abadi,\par\pard\plain\hyphpar} {	
begitu jugalah generasi keturunan umat-Ku akan abadi.\par\pard\plain\hyphpar} {	
 {\b
23} Dari pekan ke pekan, dari bulan ke bulan,\par\pard\plain\hyphpar} {	
setiap hari Sabat dan setiap hari raya,\par\pard\plain\hyphpar} {	
semua manusia akan berdatangan ke rumah-Ku dan menyembah Aku.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
24} Ketika umat-Ku memandang keluar dari Yerusalem,\par\pard\plain\hyphpar} {	
tampaklah bergelimpangan mayat orang-orang yang telah melawan Aku.\par\pard\plain\hyphpar} {	
Belatung yang menggerogoti mereka tidak akan mati, dan api yang membakar mereka tidak akan padam.\par\pard\plain\hyphpar} {	
Umat-Ku akan memandang para pemberontak itu dengan jijik.\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } }