{\b
Nubuat ketiga tentang akhir yang indah bagi umat Allah\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Padang belantara dan tanah kering menjadi segar berbunga.\par\pard\plain\hyphpar} {	
Suasana tandus dan suram berubah menjadi sukacita.\par\pard\plain\hyphpar} {	
 {\b
2} Tanah yang tadinya gersang kini dipenuhi bunga-bunga bermekaran,\par\pard\plain\hyphpar} {	
rimbun menghijau seperti gunung Libanon, Karmel, dan padang rumput Saron.\par\pard\plain\hyphpar} {	
Tanah tandus itu menjadi permai dan riang\par\pard\plain\hyphpar} {	
karena TUHAN, Allah kita yang agung, datang dengan semarak-Nya.\par\pard\plain\hyphpar} {	
 {\b
3} Oleh sebab itu, hai semua yang lemah dan ketakutan,\par\pard\plain\hyphpar} {	
bangkitkan semangatmu!\par\pard\plain\hyphpar} {	
 {\b
4} Dan semua yang resah gelisah,\par\pard\plain\hyphpar} {	
kuatkan dirimu! Jangan takut!\par\pard\plain\hyphpar} {	
Sebab Allah kita datang membawa hukuman\par\pard\plain\hyphpar} {	
untuk membalas kejahatan musuh kita.\par\pard\plain\hyphpar} {	
Dia akan datang menyelamatkan kita!\par\pard\plain\hyphpar} {	
 {\b
5} Pada waktu itu,\par\pard\plain\hyphpar} {	
orang-orang buta akan dapat melihat,\par\pard\plain\hyphpar} {	
orang-orang tuli akan dapat mendengar.\par\pard\plain\hyphpar} {	
 {\b
6} orang lumpuh akan melompat seperti rusa,\par\pard\plain\hyphpar} {	
dan orang bisu akan bernyanyi gembira\par\pard\plain\hyphpar} {	
Ketika Allah kita datang,\par\pard\plain\hyphpar} {	
segala sesuatu menjadi indah:\par\pard\plain\hyphpar} {	
padang belantara akan mengeluarkan mata air\par\pard\plain\hyphpar} {	
bahkan di padang gurun akan mengalir sungai segar.\par\pard\plain\hyphpar} {	
 {\b
7} Padang pasir yang panas menjadi danau\par\pard\plain\hyphpar} {	
dan dari tanah kering keluar sumber air.\par\pard\plain\hyphpar} {	
Belantara yang sebelumnya menjadi tempat tinggal anjing-anjing hutan\par\pard\plain\hyphpar} {	
akan ditumbuhi tanaman-tanaman air.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
8} Lalu akan ada sebuah jalan besar yang dinamai Jalan Suci,\par\pard\plain\hyphpar} {	
khusus bagi orang-orang yang diizinkan oleh Allah.\par\pard\plain\hyphpar} {	
Orang yang bebal dan yang menajiskan diri tidak akan pernah melewati jalan itu.\par\pard\plain\hyphpar} {	
 {\b
9} Jalan itu aman, karena singa maupun binatang buas\par\pard\plain\hyphpar} {	
tidak akan melintas di sekitarnya.\par\pard\plain\hyphpar} {	
Hanya orang-orang yang diselamatkan Allah yang akan berjalan di sana.\par\pard\plain\hyphpar} {	
 {\b
10} Mereka yang sudah diselamatkan TUHAN akan kembali\par\pard\plain\hyphpar} {	
dan memasuki Yerusalem sambil bernyanyi.\par\pard\plain\hyphpar} {	
Sukacita abadi akan mereka nikmati.\par\pard\plain\hyphpar} {	
Hanya kegirangan dan kebahagiaan yang terasa.\par\pard\plain\hyphpar} {	
Dukacita dan keluh kesah tak ada lagi.\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } {\s2 \afs28
