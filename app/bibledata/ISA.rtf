Yesaya 13\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Nubuat tentang hukuman atas kerajaan Babel\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Inilah nubuat dari TUHAN tentang hukuman atas kerajaan Babel* yang dinyatakan kepada saya, Yesaya anak Amos:\par\pard\plain\hyphpar} {	
 {\b
2} Di atas sebuah bukit gundul, seseorang berdiri mengibarkan bendera perang\par\pard\plain\hyphpar} {	
sambil melambai-lambaikan tangannya memberi isyarat\par\pard\plain\hyphpar} {	
dan berteriak mengerahkan pasukannya,\par\pard\plain\hyphpar} {	
\u8220?Serbulah Babel!\par\pard\plain\hyphpar} {	
Masukilah setiap gerbang kota dan jarahlah seluruh istana para pemimpin!\u8221?\par\pard\plain\hyphpar} {	
 {\b
3} TUHAN berkata,\par\pard\plain\hyphpar} {	
\u8220?Aku sendirilah yang sudah memanggil pasukan tangguh itu.\par\pard\plain\hyphpar} {	
Dengan bangga mereka akan menjatuhkan hukuman-Ku atas Babel.\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
4} Di pegunungan terdengar kegaduhan besar\par\pard\plain\hyphpar} {	
bunyi derap langkah pasukan menyerbu.\par\pard\plain\hyphpar} {	
Pasukan yang sangat dahsyat jumlahnya!\par\pard\plain\hyphpar} {	
Tentara bangsa-bangsa bergabung menjadi satu,\par\pard\plain\hyphpar} {	
digerakkan oleh TUHAN Panglima Semesta.\par\pard\plain\hyphpar} {	
 {\b
5} Mereka datang dari negeri-negeri yang jauh,\par\pard\plain\hyphpar} {	
diutus TUHAN sebagai alat untuk menyatakan murka-Nya.\par\pard\plain\hyphpar} {	
Melalui mereka, TUHAN akan memusnahkan seluruh negeri Babel.\par\pard\plain\hyphpar} {	
 {\b
6} Merataplah, hai bangsa Babel,\par\pard\plain\hyphpar} {	
sebab hari penghukuman TUHAN sudah dekat!\par\pard\plain\hyphpar} {	
Yang Mahakuasa akan membinasakan kalian sebentar lagi.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
7} Semua orang menjadi lemas ketakutan\par\pard\plain\hyphpar} {	
dan menciutlah nyali mereka.\par\pard\plain\hyphpar} {	
 {\b
8} Kengerian mencekam!\par\pard\plain\hyphpar} {	
Bangsa Babel dilumpuhkan oleh kesesakan\par\pard\plain\hyphpar} {	
