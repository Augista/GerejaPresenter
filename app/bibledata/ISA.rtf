{\b
Yesaya 29\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Pesan TUHAN: Yerusalem akan dikepung lalu diselamatkan\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} TUHAN berkata:\par\pard\plain\hyphpar} {	
Malapetaka akan menimpa Bukit Sion,* kota mezbah Daud!\par\pard\plain\hyphpar} {	
Sekalipun tahun demi tahun pesta hari raya rutin diadakan di sana,\par\pard\plain\hyphpar} {	
 {\b
2} Aku akan tetap mendatangkan musibah atas Yerusalem\par\pard\plain\hyphpar} {	
sehingga penduduknya berkabung dan meratap.\par\pard\plain\hyphpar} {	
Bukit Sion akan menjadi seperti mezbah di mana para penduduknya dihanguskan.\par\pard\plain\hyphpar} {	
 {\b
3} Aku akan menempatkan musuh-musuh di sekeliling Yerusalem.\par\pard\plain\hyphpar} {	
Mereka akan menimbun tanah menjadi tembok pengepungan di luar benteng kotamu\par\pard\plain\hyphpar} {	
sehingga kalian terkurung di dalam.\par\pard\plain\hyphpar} {	
 {\b
4} Maka kalian seakan dikubur hidup-hidup.\par\pard\plain\hyphpar} {	
Ketika kalian berseru, suaramu hanya terdengar seperti bisikan lirih dari dalam tanah.\par\pard\plain\hyphpar} {	
Kalian akan terkubur begitu dalam dan tidak berdaya.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
5} Akan tetapi, kemudian semua musuhmu akan menghilang\par\pard\plain\hyphpar} {	
seperti debu halus diterbangkan angin.\par\pard\plain\hyphpar} {	
Sekalipun mereka ganas dan banyak jumlahnya,\par\pard\plain\hyphpar} {	
mereka akan lenyap dalam sekejap, seperti sekam ditiup angin.\par\pard\plain\hyphpar} {	
Karena dengan tiba-tiba,\par\pard\plain\hyphpar} {	
 {\b
6} Aku, TUHAN Panglima Semesta, akan datang kepadamu\par\pard\plain\hyphpar} {	
dengan guntur, gempa bumi, dan bunyi-bunyi yang dahsyat,\par\pard\plain\hyphpar} {	
dengan angin ribut dan badai serta api yang menghanguskan.\par\pard\plain\hyphpar} {	
 {\b
7} Bangsa-bangsa yang mengepung benteng Sion, tempat mezbah-Ku,\par\pard\plain\hyphpar} {	
dan membuat penduduknya menderita,\par\pard\plain\hyphpar} {	
akan menghilang begitu saja seperti mimpi belaka.\par\pard\plain\hyphpar} {	
 {\b
8} Lagipula impian musuh-musuh itu tidak akan menjadi nyata.\par\pard\plain\hyphpar} {	
Seperti orang yang lapar bermimpi sedang makan\par\pard\plain\hyphpar} {	
namun bangun tanpa merasa kenyang,\par\pard\plain\hyphpar} {	
atau orang yang haus bermimpi sedang minum\par\pard\plain\hyphpar} {	
namun tetap haus saat terbangun,\par\pard\plain\hyphpar} {	
demikianlah bangsa-bangsa yang memerangi Bukit Sion bermimpi dapat mengalahkannya, tetapi gagal.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Teguran Yesaya terhadap para nabi\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
9} Hai para nabi, kalian membodohi diri,\par\pard\plain\hyphpar} {	
maka kalian benar-benar menjadi bodoh!\par\pard\plain\hyphpar} {	
Kalian membutakan diri,\par\pard\plain\hyphpar} {	
maka kalian benar-benar menjadi buta!\par\pard\plain\hyphpar} {	
Kalian seperti orang mabuk, tetapi bukan karena anggur,\par\pard\plain\hyphpar} {	
terhuyung-huyung, tetapi bukan karena minuman keras,\par\pard\plain\hyphpar} {	
 {\b
10} melainkan karena TUHAN sudah membuat kesadaranmu tumpul\par\pard\plain\hyphpar} {	
seperti orang yang tertidur pulas.\par\pard\plain\hyphpar} {	
TUHAN sudah menutup mata kalian, hai para nabi,\par\pard\plain\hyphpar} {	
dan menutupi mukamu sehingga kalian tidak dapat melihat.\par\pard\plain\hyphpar} {	
 {\b
11} Semua penglihatan ini bagimu seperti buku yang tertutup dan disegel.\par\pard\plain\hyphpar} {	
Ketika diberikan kepada orang yang bisa membaca,\par\pard\plain\hyphpar} {	
orang itu menjawab, \u8220?Aku tidak bisa, karena buku ini disegel.\u8221?\par\pard\plain\hyphpar} {	
 {\b
12} Ketika diberikan kepada orang yang buta huruf,\par\pard\plain\hyphpar} {	
orang itu menjawab, \u8220?Aku tidak bisa membaca.\u8221?\par\pard\plain\hyphpar} {	
Begitulah matamu sudah tertutup dan kesadaranmu sudah tumpul.\par\pard\plain\hyphpar} {	
 {\b
13} TUHAN Sang Penguasa berkata:\par\pard\plain\hyphpar} {	
Hanya di mulut saja umat ini mengaku menghormati Aku dan ingin hidup dekat dengan-Ku,\par\pard\plain\hyphpar} {	
tetapi hati mereka menjauh dari-Ku.\par\pard\plain\hyphpar} {	
Percuma saja mereka mengaku menyembah Aku,\par\pard\plain\hyphpar} {	
karena yang mereka ajarkan hanya aturan-aturan manusia\par\pard\plain\hyphpar} {	
dan bukan aturan-Ku.\par\pard\plain\hyphpar} {	
 {\b
14} Karena itu, perhatikanlah!\par\pard\plain\hyphpar} {	
Aku akan mengadakan lagi perbuatan ajaib di antara mereka,\par\pard\plain\hyphpar} {	
begitu ajaibnya sehingga orang pandai dan bijak pun tidak mampu mengerti.\par\pard\plain\hyphpar} {	
Pengetahuan dan pikiran mereka tidak akan dapat memahaminya.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Yesaya mengecam orang yang meremehkan TUHAN\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
15} Malapetaka akan menimpa kalian, hai orang-orang yang berusaha menyembunyikan rencanamu dari TUHAN.\par\pard\plain\hyphpar} {	
Kalian melakukan perbuatan jahat dengan sembunyi-sembunyi lalu berkata,\par\pard\plain\hyphpar} {	
\u8220?Tidak ada yang melihat kita.\par\pard\plain\hyphpar} {	
Tidak ada yang mengetahui perbuatan kita.\u8221?\par\pard\plain\hyphpar} {	
 {\b
16} Kalian memutarbalikkan segala sesuatu!\par\pard\plain\hyphpar} {	
Kalian ibarat barang tanah liat yang berkata tentang perajin yang membuatnya,\par\pard\plain\hyphpar} {	
\u8220?Aku tidak dijadikan oleh manusia itu. Aku menciptakan diriku sendiri,\u8221?\par\pard\plain\hyphpar} {	
atau, \u8220?Aku lebih pintar dari tukang itu.\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Nubuat Yesaya: Kebahagiaan sempurna di masa depan\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
17} Tidak lama lagi,\par\pard\plain\hyphpar} {	
hutan aras Libanon akan menjadi kebun buah-buahan,\par\pard\plain\hyphpar} {	
dan kebun buah-buahan semakin rimbun seperti hutan lebat.\par\pard\plain\hyphpar} {	
 {\b
18} Pada waktu itu orang yang tuli akan mendengar nubuatan ini,\par\pard\plain\hyphpar} {	
dan orang yang buta akan melihat.\par\pard\plain\hyphpar} {	
 {\b
19} Orang yang rendah hati akan menikmati sukacita karena TUHAN,\par\pard\plain\hyphpar} {	
dan orang yang miskin akan bersukaria karena Dia, Yang Mahakudus Allah Israel.\par\pard\plain\hyphpar} {	
 {\b
20} Orang-orang yang kejam dan para pencemooh tidak akan ada lagi.\par\pard\plain\hyphpar} {	
Para pelaku kejahatan akan dilenyapkan.\par\pard\plain\hyphpar} {	
 {\b
21} Para pendusta yang memberi kesaksian palsu,\par\pard\plain\hyphpar} {	
yang memutarbalikkan kebenaran di pengadilan sehingga merugikan orang tak bersalah,\par\pard\plain\hyphpar} {	
mereka semua akan dibinasakan.\par\pard\plain\hyphpar} {	
 {\b
22} Beginilah perkataan TUHAN, yang menyelamatkan Abraham, tentang semua keturunan Yakub:\par\pard\plain\hyphpar} {	
Bangsa Israel tidak akan lagi dipermalukan dan kehilangan muka,\par\pard\plain\hyphpar} {	
 {\b
23} karena ketika mereka melihat betapa besar\par\pard\plain\hyphpar} {	
jumlah anak cucu penerus Israel yang Aku jadikan,\par\pard\plain\hyphpar} {	
mereka akan memuliakan Aku, Yang Kudus Allah Yakub.\par\pard\plain\hyphpar} {	
Mereka akan takjub kepada-Ku, Allah Israel.\par\pard\plain\hyphpar} {	
 {\b
24} Pikiran mereka yang tadinya sesat akan sadar,\par\pard\plain\hyphpar} {	
dan mereka yang tadinya bersungut-sungut akan bersedia menerima pengajaran.\par\pard\plain\hyphpar} {	
