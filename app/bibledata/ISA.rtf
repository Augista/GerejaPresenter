\par\pard\plain\hyphpar} {	
 {\b
5} Hai Babel, tutup mulutmu dan duduklah diam.\par\pard\plain\hyphpar} {	
Kalian akan diangkut menjadi tawanan.\par\pard\plain\hyphpar} {	
Babel tidak akan lagi disebut ratu di antara semua kerajaan.\par\pard\plain\hyphpar} {	
 {\b
6} Sebab beginilah kata TUHAN:\par\pard\plain\hyphpar} {	
Dahulu, ketika Aku marah kepada umat-Ku\par\pard\plain\hyphpar} {	
dan menyingkirkan mereka dari kedudukan sebagai milik-Ku yang istimewa,\par\pard\plain\hyphpar} {	
Aku menyerahkan mereka ke dalam kuasamu.\par\pard\plain\hyphpar} {	
Tetapi kalian sama sekali tidak menunjukkan belas kasihan.\par\pard\plain\hyphpar} {	
Bahkan orang-orangnya yang tua renta kalian perlakukan sangat kejam.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
7} Hai Babel, kalian menyangka bangsamu akan selamanya menjadi yang paling berkuasa.\par\pard\plain\hyphpar} {	
Karena itu kalian tidak berpikir sebelum bertindak\par\pard\plain\hyphpar} {	
dan tidak mempertimbangkan akibat dari perbuatanmu.\par\pard\plain\hyphpar} {	
 {\b
8} Namun dengarlah ini, hai bangsa yang hidup enak dan merasa aman!\par\pard\plain\hyphpar} {	
Kalian berkata dalam hati,\par\pard\plain\hyphpar} {	
\u8220?Akulah yang tertinggi. Tak ada yang setara denganku.\par\pard\plain\hyphpar} {	
Aku tidak akan pernah kehilangan rajaku ataupun rakyatku.\u8221?\par\pard\plain\hyphpar} {	
 {\b
9} Tetapi justru dua hal itu akan menimpamu dalam sekejap:\par\pard\plain\hyphpar} {	
Kalian akan kehilangan rakyatmu.\par\pard\plain\hyphpar} {	
Rajamu akan ditewaskan.\par\pard\plain\hyphpar} {	
Malapetaka itu akan menghantam kalian\par\pard\plain\hyphpar} {	
sekalipun ilmu sihir dan mantramu begitu banyak.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
10} Kalian berbuat jahat dan merasa aman.\par\pard\plain\hyphpar} {	
Kalian berkata, \u8220?Tidak ada yang melihat perbuatanku.\u8221?\par\pard\plain\hyphpar} {	
Kalian sudah disesatkan oleh pikiran dan pengetahuanmu.\par\pard\plain\hyphpar} {	
Dalam hati, kalian berkata,\par\pard\plain\hyphpar} {	
\u8220?Akulah yang tertinggi. Tak ada yang setara denganku.\u8221?\par\pard\plain\hyphpar} {	
 {\b
11} Tetapi akan datang bencana menimpamu\par\pard\plain\hyphpar} {	
dan kalian tidak tahu mantra untuk menangkalnya.\par\pard\plain\hyphpar} {	
Malapetaka akan menerpamu\par\pard\plain\hyphpar} {	
dan kalian tidak tahu cara mengatasinya.\par\pard\plain\hyphpar} {	
Kehancuran akan melanda negerimu\par\pard\plain\hyphpar} {	
sebelum kalian dapat meramalkannya.\par\pard\plain\hyphpar} {	
 {\b
12} Coba saja menggunakan ilmu sihir dan mantramu yang banyak itu\par\pard\plain\hyphpar} {	
yang sudah kalian pakai sejak dulu kala.\par\pard\plain\hyphpar} {	
Barangkali sihirmu bisa berhasil.\par\pard\plain\hyphpar} {	
Mungkin saja ada yang takut terhadapnya.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
13} Para peramalmu memelototi langit,\par\pard\plain\hyphpar} {	
menatap bintang-bintang, dan mengamati bulan\par\pard\plain\hyphpar} {	
untuk mengetahui apa yang akan terjadi di depan.\par\pard\plain\hyphpar} {	
Tetapi ramalan mereka yang banyak hanya akan membuatmu pusing!\par\pard\plain\hyphpar} {	
Mereka tidak akan dapat menyelamatkanmu.\par\pard\plain\hyphpar} {	
 {\b
14} Jangankan menyelamatkanmu,\par\pard\plain\hyphpar} {	
mereka bahkan tidak bisa menyelamatkan diri sendiri.\par\pard\plain\hyphpar} {	
Orang yang mengandalkan ramalan akan hangus seperti jerami dilalap api.\par\pard\plain\hyphpar} {	
Dan apakah gunanya jerami yang terbakar?\par\pard\plain\hyphpar} {	
Apinya bahkan tidak tahan lama seperti arang\par\pard\plain\hyphpar} {	
yang bisa dipakai untuk duduk menghangatkan badan.\par\pard\plain\hyphpar} {	
 {\b
15} Demikianlah para peramal tidak berguna bagimu.\par\pard\plain\hyphpar} {	
Meskipun sejak dulu kalian mempercayakan diri pada mereka,\par\pard\plain\hyphpar} {	
orang-orang itu akan berlari menyelamatkan dirinya masing-masing.\par\pard\plain\hyphpar} {	
Tidak akan ada yang menolongmu, hai Babel.\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } {\s2 \afs28
{\b
Yesaya 48\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {\s6 \afs21
{\b
TUHAN berjanji mengutus raja penyelamat Israel\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Dengarkanlah ini, hai orang Yehuda dan Israel.\par\pard\plain\hyphpar} {	
Kalian mengaku dirimu bangsa keturunan Yakub.\par\pard\plain\hyphpar} {	
Kalian menyebut-nyebut Aku, TUHAN Allah Israel, sebagai Allahmu,\par\pard\plain\hyphpar} {	
bahkan memakai nama-Ku untuk bersumpah.\par\pard\plain\hyphpar} {	
Tetapi kata-katamu hanya dusta dan omong kosong.\par\pard\plain\hyphpar} {	
 {\b
2} Meskipun begitu, kalian membangga-banggakan diri sebagai penduduk kota suci Yerusalem\par\pard\plain\hyphpar} {	
dan mengaku bersandar kepada TUHAN Panglima Semesta, Allah Israel.\par\pard\plain\hyphpar} {	
 {\b
3} Dengarlah!\par\pard\plain\hyphpar} {	
Sudah sejak lama Aku memberitahukan apa yang akan terjadi.\par\pard\plain\hyphpar} {	
Dan sekarang dengan tiba-tiba Aku membuatnya terjadi.\par\pard\plain\hyphpar} {	
 {\b
4} Karena Aku tahu kalian sangat membangkang,\par\pard\plain\hyphpar} {	
tebal muka, tegar tengkuk, kepala batu!\par\pard\plain\hyphpar} {	
 {\b
5} Itu sebabnya dari jauh-jauh hari Aku sudah memberitahumu lebih dulu,\par\pard\plain\hyphpar} {	
supaya ketika hal itu terjadi, kalian tidak berkata,\par\pard\plain\hyphpar} {	
\u8220?Ini adalah perbuatan dewaku.\par\pard\plain\hyphpar} {	
Patung kayu dan patung logamku yang mengadakannya.\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
6} Kini semua perkataan-Ku sudah terjadi.\par\pard\plain\hyphpar} {	
Kalian sendiri sudah melihatnya.\par\pard\plain\hyphpar} {	
Apakah sekarang kalian masih tidak mau mengakui bahwa perkataan-Ku benar?\par\pard\plain\hyphpar} {	
Tetapi mulai sekarang Aku memberitahukan hal-hal baru yang akan datang,\par\pard\plain\hyphpar} {	
rahasia yang belum pernah kalian ketahui.\par\pard\plain\hyphpar} {	
 {\b
7} Ini sesuatu yang baru Aku buat. Dahulu belum ada.\par\pard\plain\hyphpar} {	
Sebelum ini, kalian tidak pernah mendengarnya.\par\pard\plain\hyphpar} {	
Maka kalian tak mungkin bisa berkata,\par\pard\plain\hyphpar} {	
\u8220?Oh, yang ini aku sudah tahu.\u8221?\par\pard\plain\hyphpar} {	
 {\b
8} Sejak dulu kalian tidak mau mendengar dan tidak mau percaya.\par\pard\plain\hyphpar} {	
Sungguh, Aku tahu bahwa sejak semula kalian adalah bangsa pembangkang\par\pard\plain\hyphpar} {	
dan kalian pasti berkhianat.\par\pard\plain\hyphpar} {	
 {\b
9} Tetapi Aku menahan amarah-Ku dan tidak memusnahkan kalian demi kehormatan-Ku,\par\pard\plain\hyphpar} {	
supaya nama-Ku tetap terpuji di antara bangsa-bangsa sebagai Allah yang menepati janji.\par\pard\plain\hyphpar} {	
 {\b
10} Itulah sebabnya Aku sudah memurnikan kalian dengan tekanan penderitaan,\par\pard\plain\hyphpar} {	
seperti perak dimurnikan dengan api yang sangat panas.\par\pard\plain\hyphpar} {	
 {\b
11} Aku melakukan itu demi kehormatan-Ku,\par\pard\plain\hyphpar} {	
yakni supaya nama-Ku tidak dicemooh\par\pard\plain\hyphpar} {	
dan supaya kalian tidak memuja dewa-dewa untuk menggantikan Aku.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
12} Dengarlah Aku, hai bangsa Israel, umat yang Aku pilih.\par\pard\plain\hyphpar} {	
Akulah Allahmu.\par\pard\plain\hyphpar} {	
Sebelum segalanya ada, Aku sudah ada.\par\pard\plain\hyphpar} {	
Dan sekalipun semuanya lenyap, Aku akan tetap ada.\par\pard\plain\hyphpar} {	
 {\b
13} Dengan tangan-Ku sendiri, Aku meletakkan dasar bumi.\par\pard\plain\hyphpar} {	
Aku sendiri yang membentangkan langit.\par\pard\plain\hyphpar} {	
Atas perkataan-Ku semuanya itu muncul dan menjadi ada.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
14} Berkumpullah kalian semua dan dengarkan!\par\pard\plain\hyphpar} {	
Tidak ada satu pun dewa yang pernah memberitahukan hal-hal ini.\par\pard\plain\hyphpar} {	
Seseorang* yang sudah Aku pilih dan kasihi akan melaksanakan rencana-Ku\par\pard\plain\hyphpar} {	
untuk menumpas kerajaan Babel.\par\pard\plain\hyphpar} {	
 {\b
15} Aku sendirilah yang telah memanggil dan menugaskan dia.\par\pard\plain\hyphpar} {	
Aku sendiri yang menggerakkan dia, dan misinya pasti berhasil.\par\pard\plain\hyphpar} {	
 {\b
16} Datanglah lebih dekat kepada-Ku dan dengarkan ini:\par\pard\plain\hyphpar} {	
Sejak semula Aku memberitahukan pesan-Ku dengan jelas.\par\pard\plain\hyphpar} {	
Sejak permulaan seluruh peristiwa ini Akulah yang mengerjakannya.\par\pard\plain\hyphpar} {	
Saya, Yesaya, mengakui bahwa TUHAN sudah mengutus saya, dan Roh-Nya membenarkan bahwa pesan ini {\b
17} berasal dari Yang Mahakudus Allah Israel, Penebus kita:\par\pard\plain\hyphpar} {	
Akulah TUHAN, Allahmu, yang mengajarkan apa yang baik bagimu\par\pard\plain\hyphpar} {	
dan menuntunmu di jalan benar yang harus kamu tempuh.\par\pard\plain\hyphpar} {	
 {\b
18} Kalau saja kalian mau taat pada perintah-Ku,\par\pard\plain\hyphpar} {	
hidupmu akan berlimpah dengan ketenangan seperti aliran sungai.\par\pard\plain\hyphpar} {	
Keadilan akan meluap di antara kalian seperti ombak lautan.\par\pard\plain\hyphpar} {	
 {\b
19} Keturunanmu akan sebanyak butiran pasir.\par\pard\plain\hyphpar} {	
Anak-cucumu tidak akan pernah mengalami kehancuran\par\pard\plain\hyphpar} {	
ataupun terusir dari negeri-Ku.\par\pard\plain\hyphpar} {	
 {\b
20} Tetapi kalian sudah ditawan di Babel.\par\pard\plain\hyphpar} {	
Meski begitu, sekarang Aku perintahkan kalian pergi dari situ.\par\pard\plain\hyphpar} {	
Aku memanggilmu keluar dari Babel, negeri orang Kasdim!\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
Beritakanlah dengan sorak-sorai ke seluruh penjuru bumi,\par\pard\plain\hyphpar} {	
\u8220?TUHAN sudah menyelamatkan Israel, hamba-Nya!\par\pard\plain\hyphpar} {	
 {\b
21} Dia membawa kami melalui padang gurun.\par\pard\plain\hyphpar} {	
Tetapi kami tidak kehausan karena Dia membelah batu\par\pard\plain\hyphpar} {	
dan mengeluarkan air dari situ!\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
22} Tetapi bagi orang jahat, tidak ada hidup tenang.\par\pard\plain\hyphpar} {	
Aku TUHAN menegaskannya.\par\pard\plain\hyphpar} {	
\u8472? {\b
48:14} Yes. 44:28; 45:1\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } {\s2 \afs28
{\b
Yesaya 49\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Nubuat kedua tentang sang hamba utusan TUHAN\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Dengarkanlah aku,* hai bangsa-bangsa, bahkan di negeri yang jauh.\par\pard\plain\hyphpar} {	
Sejak aku dalam kandungan ibuku,\par\pard\plain\hyphpar} {	
TUHAN sudah memanggilku secara khusus menjadi hamba-Nya.*\par\pard\plain\hyphpar} {	
 {\b
2} Dia menugaskanku untuk menyampaikan pesan-pesan yang menusuk bagaikan pedang dan panah.\par\pard\plain\hyphpar} {	
Maka aku ibarat senjata di tangan-Nya\par\pard\plain\hyphpar} {	
yang Dia poles mengkilap dan dijaga-Nya baik-baik.\par\pard\plain\hyphpar} {	
 {\b
3} TUHAN berkata kepadaku,\par\pard\plain\hyphpar} {	
\u8220?Kamu adalah hamba-Ku yang menggenapi perjanjian-Ku dengan Israel.\par\pard\plain\hyphpar} {	
Oleh karenamu, Aku akan dipermuliakan.\u8221?\par\pard\plain\hyphpar} {	
 {\b
4} Tetapi aku menjawab,\par\pard\plain\hyphpar} {	
\u8220?Rasanya, yang sudah aku lakukan selama ini sia-sia saja.\par\pard\plain\hyphpar} {	
Aku bekerja sekuat tenaga, tetapi hasilnya tidak ada.\par\pard\plain\hyphpar} {	
Meski begitu, aku yakin TUHAN itu adil.\par\pard\plain\hyphpar} {	
Allah pasti akan memperhitungkan kerja kerasku.\par\pard\plain\hyphpar} {	
 {\b
5} Tetapi sekarang aku mendengar TUHAN berjanji\u8212?\par\pard\plain\hyphpar} {	
yaitu Dia yang membentuk aku sejak dalam kandungan,\par\pard\plain\hyphpar} {	
yang memandangku berharga dan menguatkan aku,\par\pard\plain\hyphpar} {	
juga menugaskan aku sebagai hamba-Nya\par\pard\plain\hyphpar} {	
untuk mengumpulkan Israel dan membawa mereka kembali kepada-Nya\u8212?\par\pard\plain\hyphpar} {	
Dia berkata,\par\pard\plain\hyphpar} {	
 {\b
6} \u8216?Lebih dari sekedar mengembalikan umat Israel kepada-Ku,\par\pard\plain\hyphpar} {	
Aku mengutus kamu bagaikan terang bagi segala bangsa di bumi.\par\pard\plain\hyphpar} {	
Melalui kamu, keselamatan dari-Ku akan disampaikan ke seluruh penjuru bumi.\u8217?\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
7} TUHAN, Yang Mahakudus, Penebus Israel,\par\pard\plain\hyphpar} {	
berkata kepada hamba-Nya yang dipandang rendah manusia,\par\pard\plain\hyphpar} {	
dihina bangsa-bangsa,\par\pard\plain\hyphpar} {	
dan diperbudak oleh pemimpin-pemimpin asing:\par\pard\plain\hyphpar} {	
Kamu akan dihormati oleh bangsa-bangsa.\par\pard\plain\hyphpar} {	
Sewaktu para raja dan pejabat melihatmu,\par\pard\plain\hyphpar} {	
mereka akan tersungkur menyembah,\par\pard\plain\hyphpar} {	
karena Aku TUHAN, Sang Kudus Allah Israel, sudah memilihmu\par\pard\plain\hyphpar} {	
dan membuktikan kesetiaan-Ku kepadamu.\par\pard\plain\hyphpar} {	
 {\b
8} Aku akan menjawab doamu pada waktu yang tepat.\par\pard\plain\hyphpar} {	
Aku akan menolongmu ketika tiba waktunya menyelamatkan.\par\pard\plain\hyphpar} {	
Aku akan menjagamu dan menjadikanmu penggenap perjanjian-Ku bagi segala bangsa.\par\pard\plain\hyphpar} {	
Negeri Israel yang terbengkalai akan dihuni kembali,\par\pard\plain\hyphpar} {	
dan kamulah yang akan membagikan warisan tanah bagi umat.\par\pard\plain\hyphpar} {	
 {\b
9} Kamu akan berkata kepada para tahanan, \u8220?Keluarlah!\u8221?\par\pard\plain\hyphpar} {	
Dan kepada yang tinggal dalam penjara gelap, kamu akan memanggil mereka, \u8220?Marilah ke tempat yang terang!\u8221?\par\pard\plain\hyphpar} {	
Kamu bagaikan gembala yang akan menggiring kawanan domba itu pulang ke negeri-Ku\par\pard\plain\hyphpar} {	
dan dalam perjalanan, kamu akan menyediakan makanan bagi mereka\par\pard\plain\hyphpar} {	
bahkan saat melewati bukit-bukit yang kering kerontang.\par\pard\plain\hyphpar} {	
 {\b
10} Mereka tidak akan kelaparan ataupun kehausan.\par\pard\plain\hyphpar} {	
Terik matahari tak akan menyengat mereka.\par\pard\plain\hyphpar} {	
Angin panas tak akan menyakiti mereka.\par\pard\plain\hyphpar} {	
Sebab mereka dipimpin olehmu, hamba-Ku yang mengasihani mereka.\par\pard\plain\hyphpar} {	
Kamu akan menuntun mereka ke sumber-sumber air.\par\pard\plain\hyphpar} {	
 {\b
11} Aku akan meratakan gunung-gunung untuk melancarkan jalan mereka.\par\pard\plain\hyphpar} {	
 {\b
12} Maka umat-Ku yang dari jauh akan berdatangan.\par\pard\plain\hyphpar} {	
Dari timur, barat, utara, dan daerah Sinim di selatan, semuanya akan datang!\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Janji pemulihan Yerusalem\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
13} Bernyanyilah dengan riang, hai semua yang di surga!\par\pard\plain\hyphpar} {	
Bersoraklah dengan sukacita, hai penduduk bumi.\par\pard\plain\hyphpar} {	
Biarlah gunung-gunung seolah melompat dengan girang\par\pard\plain\hyphpar} {	
sebab TUHAN sudah menghiburkan umat-Nya.\par\pard\plain\hyphpar} {	
Dia menyatakan belas kasihan bagi mereka yang telah menderita.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
14} Akan tetapi, bagi penduduk Yerusalem yang pernah berkata,\par\pard\plain\hyphpar} {	
\u8220?TUHAN sudah mengabaikan dan meninggalkan kita,\u8221?\par\pard\plain\hyphpar} {	
 {\b
15} beginilah jawab TUHAN:\par\pard\plain\hyphpar} {	
Mungkinkah seorang ibu mengabaikan anak yang disusuinya?\par\pard\plain\hyphpar} {	
Mungkinkah seorang ibu tidak menyayangi anak yang dilahirkannya?\par\pard\plain\hyphpar} {	
Ya, mungkin saja ada ibu yang seperti itu.\par\pard\plain\hyphpar} {	
Tetapi Aku tidak mungkin mengabaikanmu!\par\pard\plain\hyphpar} {	
 {\b
16} Ketahuilah, nama Yerusalem sudah terukir di hati-Ku.\par\pard\plain\hyphpar} {	
Maka Aku pasti mengingat kalian selalu.\par\pard\plain\hyphpar} {	
 {\b
17} Yerusalem akan segera dibangun kembali.\par\pard\plain\hyphpar} {	
Dan para penghancur yang menggempurnya akan pergi.\par\pard\plain\hyphpar} {	
 {\b
18} Pandanglah berkeliling dan lihatlah.\par\pard\plain\hyphpar} {	
Para penduduknya yang tercerai-berai berdatangan pulang ke Yerusalem.\par\pard\plain\hyphpar} {	
Demi diri-Ku sendiri sebagai TUHAN Allah yang hidup, Aku bersumpah:\par\pard\plain\hyphpar} {	
Kota Yerusalem akan selalu diwarnai oleh kehadiran penduduknya\par\pard\plain\hyphpar} {	
seperti seorang mempelai dipercantik dengan gaun pengantin dan perhiasan.\par\pard\plain\hyphpar} {	
 {\b
19} Walaupun sekarang Yerusalem terlantar, hancur, dan terbengkalai,\par\pard\plain\hyphpar} {	
kelak penduduknya akan begitu banyak\par\pard\plain\hyphpar} {	
hingga kota itu seakan terlalu kecil.\par\pard\plain\hyphpar} {	
Musuh-musuh yang menggempurnya akan pergi jauh-jauh.\par\pard\plain\hyphpar} {	
 {\b
20} Dahulu Yerusalem kosong ditinggalkan penduduknya.\par\pard\plain\hyphpar} {	
Tetapi sementara kota Yerusalem merana, penduduknya yang terserak di negeri-negeri asing telah beranak cucu.\par\pard\plain\hyphpar} {	
Kelak mereka semua bersama keturunannya akan kembali,\par\pard\plain\hyphpar} {	
sehingga mereka berkata satu sama lain,\par\pard\plain\hyphpar} {	
\u8220?Kota ini terlalu kecil untuk kita semua.\par\pard\plain\hyphpar} {	
Mari kita perluas Yerusalem.\u8221?\par\pard\plain\hyphpar} {	
 {\b
21} Maka seandainya kota bisa berbicara, tentulah Yerusalem akan berkata,\par\pard\plain\hyphpar} {	
\u8220?Luar biasa! Ternyata pendudukku sebanyak ini!\par\pard\plain\hyphpar} {	
Aku tidak pernah melihat mereka lahir.\par\pard\plain\hyphpar} {	
Meskipun tadinya aku ditinggalkan sendiri,\par\pard\plain\hyphpar} {	
tandus dan gersang seperti kota mati,\par\pard\plain\hyphpar} {	
sekarang aku menjadi hidup!\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
22} Beginilah kata TUHAN Sang Penguasa:\par\pard\plain\hyphpar} {	
Ketahuilah, Aku akan memberi komando kepada bangsa-bangsa\par\pard\plain\hyphpar} {	
supaya mereka memulangkan kalian, umat-Ku, penduduk Yerusalem.\par\pard\plain\hyphpar} {	
Mereka akan mengantar kalian kembali ke tanah airmu.\par\pard\plain\hyphpar} {	
Di bahu mereka, anak-anakmu lelaki dan perempuan digendong.\par\pard\plain\hyphpar} {	
 {\b
23} Para raja bangsa-bangsa dan ratu-ratu mereka\par\pard\plain\hyphpar} {	
