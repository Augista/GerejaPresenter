{\b
Nubuat Yesaya: Penghakiman atas seluruh bumi\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Perhatikanlah, hai bangsa-bangsa!\par\pard\plain\hyphpar} {	
Inilah pesan untuk seluruh dunia, untuk semua manusia di bumi.\par\pard\plain\hyphpar} {	
Dengarkanlah!\par\pard\plain\hyphpar} {	
 {\b
2} TUHAN murka kepada segala bangsa beserta segenap rakyatnya.\par\pard\plain\hyphpar} {	
Karena itu Dia telah menetapkan agar semuanya dihancurkan dan orang-orangnya dihabisi.\par\pard\plain\hyphpar} {	
 {\b
3} Mayat-mayat mereka akan dibiarkan bergelimpangan\par\pard\plain\hyphpar} {	
sehingga bau busuknya menguar di mana-mana.\par\pard\plain\hyphpar} {	
Pertumpahan darah akan begitu banyak\par\pard\plain\hyphpar} {	
sehingga gunung-gunung pun seakan terendam oleh darah.\par\pard\plain\hyphpar} {	
 {\b
4} Bentangan langit akan lenyap seperti kitab digulung.\par\pard\plain\hyphpar} {	
Semua benda angkasa mengering dan berjatuhan\par\pard\plain\hyphpar} {	
seperti daun-daun gugur.\par\pard\plain\hyphpar} {	
 {\b
5} Karena penghakiman TUHAN bagaikan pedang\par\pard\plain\hyphpar} {	
yang menghabisi segala yang ada di langit.\par\pard\plain\hyphpar} {	
Setelah selesai penghakiman-Nya atas langit,\par\pard\plain\hyphpar} {	
TUHAN akan menghakimi Edom,\par\pard\plain\hyphpar} {	
bangsa yang telah Dia tetapkan untuk dimusnahkan.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {\s6 \afs21
{\b
Penghakiman atas Edom\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
6} Seluruh penduduk Edom dibantai oleh pedang hukuman TUHAN,\par\pard\plain\hyphpar} {	
baik manusia maupun kambing domba\par\pard\plain\hyphpar} {	
hingga pedang TUHAN itu seolah berlumuran darah dan lemak.\par\pard\plain\hyphpar} {	
Begitu banyak yang mati tersembelih di kota Bosra,\par\pard\plain\hyphpar} {	
seakan TUHAN sedang mengadakan hari raya kurban.\par\pard\plain\hyphpar} {	
Pembantaian besar terjadi di seluruh negeri Edom.\par\pard\plain\hyphpar} {	
 {\b
7} Bahkan para penguasa Edom, yang bagaikan banteng liar yang ganas pun, akan ikut terbunuh bersama orang biasa yang lemah.\par\pard\plain\hyphpar} {	
Seluruh negeri penuh dengan darah,\par\pard\plain\hyphpar} {	
sampai tanahnya tertutup tumpahan lemak.\par\pard\plain\hyphpar} {	
 {\b
8} Sebab pada hari itu, TUHAN membalaskan segala kejahatan Edom terhadap Israel.\par\pard\plain\hyphpar} {	
 {\b
9} Sungai-sungai di Edom berubah menjadi aliran aspal panas\par\pard\plain\hyphpar} {	
dan tanahnya menjadi belerang.\par\pard\plain\hyphpar} {	
Seluruh negeri menjadi padang aspal yang terbakar.\par\pard\plain\hyphpar} {	
 {\b
10} Siang dan malam apinya tidak akan padam.\par\pard\plain\hyphpar} {	
Asapnya mengepul sampai selamanya.\par\pard\plain\hyphpar} {	
Dari zaman ke zaman negeri itu menjadi reruntuhan\par\pard\plain\hyphpar} {	
dan tidak pernah ada lagi manusia yang melintasinya.\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
11} Tetapi burung hantu, gagak, dan landak akan tinggal di sana.\par\pard\plain\hyphpar} {	
Tempat itu hanya akan menjadi sarang binatang liar.\par\pard\plain\hyphpar} {	
Seperti orang menentukan batas-batas tanah,\par\pard\plain\hyphpar} {	
demikianlah TUHAN seakan menarik garis sekeliling negeri Edom\par\pard\plain\hyphpar} {	
untuk menentukan agar seluruh daerah itu menjadi tidak berbentuk dan kosong, seperti belum pernah dihuni manusia.*\par\pard\plain\hyphpar} {	
 {\b
12} Tidak akan ada lagi bangsawan ataupun raja\par\pard\plain\hyphpar} {	
yang membuat Edom pantas disebut kerajaan.\par\pard\plain\hyphpar} {	
 {\b
13} Istana-istana dan benteng-bentengnya penuh tertutup lumut dan putri malu,\par\pard\plain\hyphpar} {	
menjadi sarang bagi anjing hutan dan burung hantu.\par\pard\plain\hyphpar} {	
 {\b
14} Di sana serigala dan segala hewan liar berkumpul.\par\pard\plain\hyphpar} {	
Kambing-kambing hutan bersahut-sahutan.\par\pard\plain\hyphpar} {	
Bahkan binatang-binatang malam tinggal dengan tenang\par\pard\plain\hyphpar} {	
karena tidak ada lagi manusia.\par\pard\plain\hyphpar} {	
 {\b
15} Edom menjadi tempat burung hantu bersarang dan bertelur serta membesarkan anak-anaknya,\par\pard\plain\hyphpar} {	
bahkan elang berdatangan ke situ untuk kawin.\par\pard\plain\hyphpar} {	
 {\b
16} Cari dan bacalah di dalam kitab TUHAN. Di situ tertulis,\par\pard\plain\hyphpar} {	
\u8220?Semua jenis hewan itu akan ada dan lengkap di padang belantara Edom.\par\pard\plain\hyphpar} {	
Tiada satu pun yang tidak ada.\par\pard\plain\hyphpar} {	
Masing-masing berpasang-pasangan.\u8221?\par\pard\plain\hyphpar} {	
Hal itu terjadi sebab TUHAN sudah mengatakannya,\par\pard\plain\hyphpar} {	
dan kuasa-Nya sendiri yang menjalankannya.\par\pard\plain\hyphpar} {	
 {\b
17} TUHAN memberikan negeri Edom sebagai tempat tinggal bagi hewan liar.\par\pard\plain\hyphpar} {	
Masing-masing diberi-Nya bagian, seperti orang membagi tanah warisan.\par\pard\plain\hyphpar} {	
Dari zaman ke zaman dan sampai selamanya,\par\pard\plain\hyphpar} {	
binatang liar menduduki negeri Edom sebagai tempat kediaman mereka.\par\pard\plain\hyphpar} {	
{\b
34:11} tidak berbentuk dan kosong Yesaya menggunakan kata yang sama dengan Kej. 1:2, \u8220?Waktu itu, bumi belum berbentuk dan kosong.\u8221?\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } {\s2 \afs28
