{\b
Nyanyian syukur umat Allah\par\pard\plain\hyphpar}\par\pard\plain\hyphpar} {	
{\b
1} Pada waktu semua itu terjadi, kalian akan berkata,\par\pard\plain\hyphpar} {	
\u8220?Aku bersyukur kepada-Mu, ya TUHAN,\par\pard\plain\hyphpar} {	
karena meskipun Engkau pernah memurkai aku,\par\pard\plain\hyphpar} {	
kini murka-Mu sudah berhenti\par\pard\plain\hyphpar} {	
dan Engkau berbalik mengasihani aku.\par\pard\plain\hyphpar} {	
 {\b
2} Sungguh, Engkaulah penyelamatku, ya Allah.\par\pard\plain\hyphpar} {	
Kepada-Mu aku percaya penuh.\par\pard\plain\hyphpar} {	
Aku tidak takut apa pun, karena TUHAN memberiku kekuatan.\par\pard\plain\hyphpar} {	
Segala nyanyianku adalah tentang-Mu\par\pard\plain\hyphpar} {	
sebab Engkau telah menyelamatkan aku.\u8221?\par\pard\plain\hyphpar} {	
\par\pard\plain\hyphpar} {	
 {\b
3} Hai umat Allah, suatu hari nanti\par\pard\plain\hyphpar} {	
kalian akan menikmati indahnya diselamatkan oleh TUHAN,\par\pard\plain\hyphpar} {	
bagaikan seorang yang haus menemukan mata air\par\pard\plain\hyphpar} {	
lalu meminumnya banyak-banyak dengan kegirangan.\par\pard\plain\hyphpar} {	
 {\b
4} Pada waktu itu kalian akan berkata,\par\pard\plain\hyphpar} {	
\u8220?Mari kita bersyukur kepada TUHAN!\par\pard\plain\hyphpar} {	
Pujilah nama-Nya.\par\pard\plain\hyphpar} {	
Ceritakanlah perbuatan-perbuatan-Nya kepada segala bangsa.\par\pard\plain\hyphpar} {	
Beritakanlah bahwa Dia agung luhur!\par\pard\plain\hyphpar} {	
 {\b
5} Bernyanyilah bagi TUHAN, karena ajaib tindakan-tindakan-Nya.\par\pard\plain\hyphpar} {	
Biarlah seluruh bumi mengetahui hal itu.\par\pard\plain\hyphpar} {	
 {\b
6} Bersoraklah dengan riang gembira, hai semua yang berada di Sion,\par\pard\plain\hyphpar} {	
karena besarlah Yang Mahakudus Allah Israel di antara kita!\u8221?\par\pard\plain\hyphpar} {\par\pard\hyphpar }{\page } {\s2 \afs28
